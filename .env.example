# Supabase (public - safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only - never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (server-only)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MONTHLY_REQUEST_CAP=100
OPENAI_REQUESTS_PER_BRIEFING_MAX=5
OPENAI_MAX_OUTPUT_TOKENS=700

# Exa (server-only)
EXA_API_KEY=your-exa-api-key
EXA_MONTHLY_REQUEST_CAP=800
EXA_REQUESTS_PER_BRIEFING_MAX=5

# Email via Gmail SMTP (server-only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_APP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=WineRadar <your-email@gmail.com>

# Cron protection (server-only)
CRON_SECRET=your-random-secret

# App
APP_URL=http://localhost:3000

# Per-user limits (used server-side; also exposed as NEXT_PUBLIC for dashboard display)
MAX_BRANDS_PER_USER=5
MAX_TOPICS_PER_USER=5
NEXT_PUBLIC_MAX_BRANDS=5
NEXT_PUBLIC_MAX_TOPICS=5
